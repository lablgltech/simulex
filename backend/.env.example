# Копируйте как .env и заполните значения.
# На продакшене: /opt/simulex/backend/.env (файл не загружается через rsync)

POSTGRES_DSN=postgresql://simulex:PASSWORD@localhost:5432/simulex

# === LLM: по умолчанию прямой OpenAI (чат + embeddings) ===
OPENAI_API_KEY=sk-proj-...
# Модель без префикса вендора → запросы на api.openai.com (или OPENAI_BASE_URL)
OPENAI_MODEL=gpt-4o-mini
# Обход гео-блока: свой прокси до OpenAI (без /v1 в конце пути).
# OPENAI_BASE_URL=https://your-host.example.com/openai
# OPENAI_PROXY_TOKEN=secret  # если прокси требует X-Internal-Token

# Таймауты (сек): при частых 502 увеличьте.
OPENAI_TIMEOUT=90
# OPENAI_CONNECT_TIMEOUT=15
PORT=5000

# --- Локально после git clone: либо DEBUG=true, либо JWT_SECRET (см. блок ниже) ---
# По умолчанию DEBUG не задан → false → в main.py fail-fast без JWT_SECRET (процесс сразу завершится).
# Для первого запуска без настройки JWT раскомментируйте одну строку:
# DEBUG=true

# === Опционально: OpenRouter (Qwen и др.) — раскомментируйте и смените OPENAI_MODEL на qwen/... ===
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=qwen/qwen3-32b

# CORS: список origins через запятую (для credentials нельзя использовать *)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# DATA_DIR=/opt/simulex/data
# DEBUG=false

# Синхронизация каталога кейсов с БД при старте uvicorn (main.py). По умолчанию при отсутствии переменной — вкл.
# На проде с общей БД и разным составом файлов на диске инстанса выставьте 0 и используйте init_db.py / админ reseed.
# RESEED_CASES_ON_STARTUP=0
# На проде с gunicorn --workers N: либо 0, либо start_prod.sh с --preload (и при желании REDIS_URL — lock на старте).

# Контент кейса для участников: из БД (case_content_json после reseed). 1 = как раньше — всегда с диска.
# GET_CASE_FROM_FILESYSTEM=0

# Опционально: Redis (кэш JSON кейса между воркерами; блокировка POST /api/admin/reseed-cases).
# REDIS_URL=redis://127.0.0.1:6379/0
# CASE_CONTENT_REDIS_TTL_SECONDS=300

# Пороги «достаточного участия» для LEXIC (JSON поверх дефолтов в config.py).
# По умолчанию: backend/config/lexic_participation.json
# LEXIC_PARTICIPATION_CONFIG_PATH=/path/to/lexic_participation.json

# Всегда использовать ИИ (без fallback на простой режим при ошибках)
# AI_ONLY_MODE=true

# --- Переговоры этап 3: v1 only (старый пайплайн chat_service + ai_chat_service + bot_logic) ---
# Переговоры этап 3: два вызова LLM (оценка JSON + живая реплика). 0 = один вызов как раньше.
# NEGOTIATION_LLM_TWO_STEP=0
# Разрешить simple-режим переговоров (get_bot_response) по history.mode — только для тестов/отладки; в UI не выставляется.
# NEGOTIATION_ALLOW_SIMPLE_MODE=1
# NEGOTIATION_STRUCT_TEMPERATURE=0.25
# NEGOTIATION_REPLY_TEMPERATURE=0.55
# NEGOTIATION_STRUCT_MAX_TOKENS=520
# NEGOTIATION_REPLY_MAX_TOKENS=450
# Вопрос игрока: больший лимит токенов на финальную реплику; мягче постобработка в chat_service (skip_aggressive_sanitize).
# NEGOTIATION_QUESTION_REPLY_MAX_TOKENS=380
# Сколько переговорных вопросов игрока по пункту (с «?») уже было в истории до текущего хода — после достижения лимита ответ без LLM: «не успеем договориться» и просьба прислать редакцию.
# NEGOTIATION_MAX_PLAYER_QUESTIONS_ANSWERED=2
# Одношаговый режим переговоров: лимит токенов JSON при вопросе.
# NEGOTIATION_QUESTION_ONESTEP_MAX_TOKENS=420
# NEGOTIATION_ONESTEP_MAX_TOKENS=600

# --- Переговоры этап 3: движок v2 (negotiation_v2_runtime) ---
# Движок переговоров v2: лимит выходных токенов на ход (JSON + message).
# NEGOTIATION_V2_MAX_TOKENS=1000
# NEGOTIATION_V2_TEMPERATURE=0.3
# v2: противоречивый JSON и дубликат реплики бота исправляются детерминированно (без второго вызова LLM).

# Понятный журнал переговоров в терминале (многострочный блок «ЖУРНАЛ ПЕРЕГОВОРОВ») — для наблюдения за диалогом без IT-терминов.
# Удобный переключатель: CHAT_LOGS_IN_TERMINAL=1 (то же: NEGOTIATION_PLAIN_LOGS=1 или READABLE_CHAT_LOGS=1).
# В main.py по умолчанию LOG_LEVEL=INFO — иначе сообщения уровня INFO в консоль не попадут.
# При включённом журнале подробные строки [NegV2] уходят в DEBUG — для них задайте LOG_LEVEL=DEBUG.
# CHAT_LOGS_IN_TERMINAL=1
# LOG_LEVEL=INFO
# При работе с http://localhost:3000 запросы /api проксируются на бэкенд :5000; логи смотрите в терминале, где запущен uvicorn.
# Копия строк [CHAT]/[API] и блока «ЖУРНАЛ ПЕРЕГОВОРОВ» пишется в backend/dev_stage3_chat_mirror.log (*.log в .gitignore).
# Просмотр логов в браузере: /simulex-logs и /api/dev/logs-view всегда отвечают (не 404).
# SIMULEX_LOG_VIEWER=0 — только отключает поток данных (заглушка + пустой recent-logs).
# Проверка, что это нужный API: GET /api/health → поле dev_log_viewer_data (true/false).

# В ответ API переговоров добавить negotiationTrace (цепочка guard/LLM/лимиты) + лог [NegotiationTrace]
# NEGOTIATION_TRACE=1

# --- Legacy / семантика (эмбеддинги + negotiation_intent_anchors; не основной путь send_message в ИИ-режиме) ---
# Нужен OPENAI_API_KEY и совместимый /v1/embeddings (при OPENAI_BASE_URL — тот же хост). OpenRouter-only без ключа OpenAI — слой отключается.
# NEGOTIATION_SEMANTIC_HINTS=0
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# NEGOTIATION_SEMANTIC_MIN_SCORE=0.28
# NEGOTIATION_INTENT_ANCHORS_PATH=data/negotiation_intent_anchors.json

# Временно отключить терпение бота (всегда 100%, лимит не срабатывает)
# DISABLE_BOT_PATIENCE=true

# ИИ-тьютор (опционально; по умолчанию — модель из конфига, например Qwen)
# TUTOR_MODEL=qwen/qwen3-32b
# TUTOR_TEMPERATURE=0.7
# TUTOR_MAX_TOKENS=500
# TUTOR_MAX_HISTORY_MESSAGES=50
# TUTOR_HISTORY_WINDOW=20
# TUTOR_EVENT_TEMPERATURE=0.6
# TUTOR_EVENT_MAX_TOKENS=150
# TUTOR_RAG_TOP_K_SEMANTIC=4
# TUTOR_RAG_TOP_K_KEYWORD=4
# TUTOR_RAG_MAX_TOTAL=8
# TUTOR_RAG_USE_KEYWORD=true

# Прокси к LLM (только на проде, по желанию)
# OPENAI_PROXY_TOKEN=secret-token-for-proxy

# JWT: на проде обязателен. Локально при DEBUG=false — тоже обязателен (иначе FATAL при старте). См. DEBUG=true выше.
# JWT_SECRET=your-long-random-secret
# Срок access-токена (минуты), по умолчанию 2880 (48 ч)
# ACCESS_TOKEN_EXPIRE_MINUTES=2880
# Админ-API: только заголовок X-Admin-Key (не вшивайте в публичный фронт). Если не задан — доступ по JWT (admin/superuser).
# ADMIN_API_KEY=your-secret-admin-key

# База знаний для RAG (каталог с .md). По умолчанию data/kb (относительно корня проекта).
# KB_DIR=data/kb

# --- Генерация кейса (админка): анкета ---
# Анкета по умолчанию идёт через structured output (Pydantic / tool calling). Выключить: CASE_GEN_QUESTIONNAIRE_STRUCTURED=0
# Метод LangChain: function_calling | json_schema | json_mode (пробуются по очереди).
# CASE_GEN_QUESTIONNAIRE_STRUCTURED_METHOD=function_calling
# Модель анкеты: только CASE_QUESTIONNAIRE_MODEL (по умолчанию openai/gpt-4o). НЕ наследует CASE_GENERATION_MODEL —
# иначе при Gemini на генерации анкета ломается (structured → парсинг текста → пустые вопросы).
# CASE_QUESTIONNAIRE_MODEL=openai/gpt-4o
# CASE_GENERATION_MODEL=google/gemini-2.5-flash-preview-05-20
# Диагностика ответа анкеты в JSON API: CASE_GEN_DIAGNOSTICS=1

# --- Мост этап 3→4: сопоставление согласованного текста с вариантами A/B/C (hybrid_match) ---
# Нечёткое совпадение: минимальный ratio и отрыв от второго кандидата (SequenceMatcher по нормализованному тексту).
STAGE4_FUZZY_MIN_RATIO=0.82
STAGE4_FUZZY_MARGIN=0.05
# 1 = после fuzzy пробовать LLM (нужен рабочий чат-API как у переговоров). 0/false — только exact/normalized/fuzzy, иначе A.
STAGE4_SELECTION_LLM_ENABLED=0
# Пусто → та же модель, что для этапа 3 (get_model_for_consumer("stage3"): ai_model_config.json + OPENAI_MODEL).
# Иначе явная модель только для моста 3→4.
# STAGE4_BRIDGE_LLM_MODEL=
# Минимальная уверенность JSON от LLM (если LLM включён): STAGE4_LLM_CONFIDENCE_MIN=0.6
